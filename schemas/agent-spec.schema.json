{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ofirm7/whaser/schemas/agent-spec.schema.json",
  "title": "Whaser AgentSpec",
  "description": "The concrete, versioned specification produced by the conversational 'Create new agent' wizard. Authored to obey Anthropic structured-output limits: additionalProperties:false everywhere, no min/max, no minLength/maxLength, no recursion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "agent_name",
    "brand_persona",
    "goal",
    "in_scope_topics",
    "out_of_scope_topics",
    "refusal_policy",
    "escalation_rules",
    "tools",
    "sub_agents",
    "workflow",
    "knowledge_sources",
    "default_language",
    "greeting",
    "fallback_message",
    "model_assignment",
    "needs_sandbox"
  ],
  "properties": {
    "version": { "type": "integer", "description": "Monotonic spec version (append-only history)." },
    "agent_name": { "type": "string", "description": "Display/brand name for the agent." },
    "brand_persona": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tone", "style_notes"],
      "properties": {
        "tone": { "type": "string", "description": "e.g. friendly, formal, terse." },
        "style_notes": { "type": "string", "description": "Freeform voice guidance." }
      }
    },
    "goal": { "type": "string", "description": "The single primary outcome the agent drives toward." },
    "in_scope_topics": { "type": "array", "items": { "type": "string" }, "description": "Must be disjoint from out_of_scope_topics (consistency check)." },
    "out_of_scope_topics": { "type": "array", "items": { "type": "string" } },
    "refusal_policy": { "type": "string", "description": "What to decline and how." },
    "escalation_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["when", "action"],
        "properties": {
          "when": { "type": "string" },
          "action": { "type": "string", "description": "e.g. handoff, escalate, collect_contact." }
        }
      }
    },
    "tools": {
      "type": "array",
      "description": "Each tool must map to a registered executor/MCP tool at runtime (consistency check). Parameters are a closed list (structured-output compatible); the runtime input_schema is derived from them at materialization.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "parameters", "side_effecting"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string", "description": "Prescriptive: 'Call this when ...'." },
          "parameters": {
            "type": "array",
            "description": "The tool's input parameters.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "type", "description", "required"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string", "description": "JSON type, e.g. string, number, boolean." },
                "description": { "type": "string" },
                "required": { "type": "boolean" }
              }
            }
          },
          "side_effecting": { "type": "boolean", "description": "If true, requires a capability flag + human-in-the-loop and runs sandboxed." }
        }
      }
    },
    "sub_agents": {
      "type": "array",
      "description": "Specialized sub-agents the workflow routes to (empty for a single-persona agent).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "specialty", "tool_names"],
        "properties": {
          "id": { "type": "string", "description": "Stable id referenced by workflow routes." },
          "name": { "type": "string" },
          "specialty": { "type": "string", "description": "What this sub-agent handles and how it should behave." },
          "tool_names": { "type": "array", "items": { "type": "string" }, "description": "Names of tools (from tools[]) this sub-agent may use." }
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "description": "How inbound messages are handled: a single default agent, or a router that classifies intent and delegates to a sub-agent.",
      "required": ["mode", "routes", "on_no_match"],
      "properties": {
        "mode": { "type": "string", "enum": ["single", "router"] },
        "routes": {
          "type": "array",
          "description": "Router mode only: intent -> sub-agent. Empty for single mode.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["intent", "description", "target"],
            "properties": {
              "intent": { "type": "string", "description": "Short intent label." },
              "description": { "type": "string", "description": "When this route applies (used by the classifier)." },
              "target": { "type": "string", "description": "sub_agents[].id that handles this intent." }
            }
          }
        },
        "on_no_match": { "type": "string", "enum": ["default", "handoff"], "description": "What to do when no route matches." }
      }
    },
    "knowledge_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "label", "content"],
        "properties": {
          "type": { "type": "string", "description": "text | url" },
          "label": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    },
    "skills": {
      "type": "array",
      "description": "Optional Claude Agent Skills (SKILL.md form) added to the agent after creation. Each skill's instructions are injected into the agent's system prompt. Optional for backward compatibility.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "instructions"],
        "properties": {
          "name": { "type": "string", "description": "Skill identifier (kebab-case)." },
          "description": { "type": "string", "description": "What it does AND when to use it (the triggering hint)." },
          "instructions": { "type": "string", "description": "Imperative SKILL.md body the agent follows." }
        }
      }
    },
    "default_language": { "type": "string", "description": "BCP-47 language tag, e.g. 'en'." },
    "greeting": { "type": "string" },
    "fallback_message": { "type": "string" },
    "model_assignment": {
      "type": "string",
      "description": "Anthropic model id. Default claude-sonnet-4-6; claude-opus-4-8 for hard-reasoning agents.",
      "enum": ["claude-sonnet-4-6", "claude-opus-4-8", "claude-haiku-4-5"]
    },
    "needs_sandbox": { "type": "boolean", "description": "If true, runtime uses the sandboxed tool executor instead of in-process tools." }
  }
}
