# Whaser environment — copy to deploy/.env and fill in. NEVER commit deploy/.env.
# This is a focused overlay; for any additional LibreChat knobs see librechat/.env.example.
# Generate secrets with:  openssl rand -hex 32   (and -hex 16 for CREDS_IV)

#=========================#
#   Core / networking     #  (Phase 0)
#=========================#
HOST=0.0.0.0
PORT=3080
UID=1000
GID=1000
# Your real public domain (DNS A-record → this VM). Used by Caddy for TLS and by LibreChat.
WHASER_DOMAIN=whaser.example.com
DOMAIN_CLIENT=https://whaser.example.com
DOMAIN_SERVER=https://whaser.example.com

#=========================#
#   Secrets (generate!)   #  (Phase 0)
#=========================#
CREDS_KEY=__openssl_rand_hex_32__
CREDS_IV=__openssl_rand_hex_16__
JWT_SECRET=__openssl_rand_hex_32__
JWT_REFRESH_SECRET=__openssl_rand_hex_32__
MEILI_MASTER_KEY=__openssl_rand_hex_32__
POSTGRES_PASSWORD=__change_me__

#=========================#
#   Auth / registration   #  (Phase 0 → Phase 1)
#=========================#
ALLOW_EMAIL_LOGIN=true
# Accounts come from the LDAP directory — disable self-service signup.
ALLOW_REGISTRATION=false

#=========================#
#   Anthropic (Claude)    #  (Phase 0)
#=========================#
ANTHROPIC_API_KEY=sk-ant-__your_key__

#=========================#
#   LDAP (LibreChat→lldap)#  (Phase 1)  — REQ 4
#=========================#
LDAP_URL=ldap://lldap:3890
LDAP_BIND_DN=uid=admin,ou=people,dc=whaser,dc=local
LDAP_BIND_CREDENTIALS=__lldap_admin_password__
LDAP_USER_SEARCH_BASE=ou=people,dc=whaser,dc=local
LDAP_LOGIN_USES_USERNAME=true

#=========================#
#   lldap server          #  (Phase 1)
#=========================#
LLDAP_BASE_DN=dc=whaser,dc=local
LLDAP_ADMIN_PASSWORD=__lldap_admin_password__
LLDAP_JWT_SECRET=__openssl_rand_hex_32__
LLDAP_KEY_SEED=__openssl_rand_hex_32__

#=========================#
#   WhatsApp Cloud API    #  (Phase 2)  — REQ 1
#=========================#
# From the Meta App dashboard. Use the LONG-LIVED System User token (not the 24h temp token).
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=__random_string_you_choose__
WHATSAPP_APP_SECRET=__meta_app_secret__
WHATSAPP_ACCESS_TOKEN=__meta_long_lived_system_user_token__
WHATSAPP_PHONE_NUMBER_ID=__meta_test_number_phone_number_id__

#=========================#
#   Whaser runtime knobs  #  (Phase 2–6)
#=========================#
# Salt for hashing inbound sender phone numbers before storage (PII).
WHASER_SENDER_HASH_SALT=__openssl_rand_hex_16__
# Conversation retention before purge.
WHASER_RETENTION_DAYS=30
# Default per-tenant daily token budget (circuit-breaker); 0 = unlimited (not recommended).
WHASER_TENANT_DAILY_TOKEN_BUDGET=2000000
# Per-sender inbound rate limit (messages / minute) and max inbound message size (chars).
WHASER_RATE_LIMIT_PER_MIN=20
WHASER_MAX_INBOUND_CHARS=4000

#=========================#
#   RAG                   #  (Phase 0)
#=========================#
RAG_PORT=8000
